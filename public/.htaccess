<IfModule mod_rewrite.c>
  RewriteEngine On

  # Если запрашиваемый файл/папка существует — отдаём как есть
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # Для многостраничного PHP-сайта отдаём index.php только для корня
  RewriteRule ^$ index.php [L]
</IfModule>
